[HKEY_CLASSES_ROOT\Folder\shell\TreeSize Free]
@="Scan with TreeSize Free"
"AppliesTo"="System.ParsingName:<>\"::{645FF040-5081-101B-9F08-00AA002F954E}\" AND System.ParsingName:<>\"::{679f85cb-0220-4080-b29b-5540cc05aab6}\" AND System.ParsingPath:~!\"::{26EE0668-A00A-44D7-9371-BEB064C98683}\" AND System.IsFolder:=System.StructuredQueryType.Boolean#True"
"Icon"="C:\\Program Files\\JAM Software\\TreeSize Free\\TreeSizeFree.exe,0"

[HKEY_CLASSES_ROOT\Folder\shell\TreeSize Free\command]
@="\"C:\\Program Files\\JAM Software\\TreeSize Free\\TreeSizeFree.exe\" \"%1\""

